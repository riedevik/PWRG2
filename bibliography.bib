@article{hirschmugl2017,
	title = {Methods for Mapping Forest Disturbance and Degradation from Optical Earth Observation Data: a Review},
	volume = {3},
	issn = {2198-6436},
	url = {https://doi.org/10.1007/s40725-017-0047-2},
	doi = {10.1007/s40725-017-0047-2},
	abstract = {This paper presents a review of the current state of the art in remote sensing-based monitoring of forest disturbances and forest degradation from optical Earth Observation data. Part one comprises an overview and tabular description of currently available optical remote sensing sensors, which can be used for forest disturbance and degradation mapping. Part two reviews the two main categories of existing mapping approaches: first, classical image-to-image change detection and second, time series analysis.},
	number = {1},
	journal = {Current Forestry Reports},
	author = {Hirschmugl, Manuela and Gallaun, Heinz and Dees, Matthias and Datta, Pawan and Deutscher, Janik and Koutsias, Nikos and Schardt, Mathias},
	month = mar,
	year = {2017},
	pages = {32--45},
}

@article{ianc2025,
	title = {Silent Crises in the Carpathians: Deforestation, Illegal Logging, and the Erosion of Ecological Resilience in Romania},
	copyright = {https://ijsmsjournal.org/volume8-issue3.html},
	issn = {2581-5946},
	shorttitle = {Silent {Crises} in the {Carpathians}},
	url = {https://ijsmsjournal.org/2025/volume-8%20issue-3/ijsms-v8i3p107.pdf},
	doi = {10.51386/25815946/ijsms-v8i3p107},
	abstract = {Romania's Carpathian forests, one of Europe's last remaining old-growth ecosystems, are experiencing an environmental crisis characterized by rampant deforestation and illegal logging. This paper critically assesses the scale, drivers, and impacts of forest degradation across Romania by integrating land-use and deforestation data from satellite imagery, governmental reports, and case studies from protected areas. Using examples of institutional vulnerabilities in forest governance, timber traceability corruption, and socio-political acceptance of environmental crime, the findings suggest that a systemic failure has driven ecological criminality. As well, the research illuminates the erosion of environmental resilience - as defined through loss of biodiversity, hydrological destabilization, and climate vulnerability - in regions affected by forest degradation. The growing discordance between Romania's international environmental responsibilities and domestic capabilities is analyzed and reported. In conclusion, the paper proposes a shift towards community-based forest stewardship, new forms of digital and transparent monitoring, and trans-national accountability frameworks to mitigate the pushing threat of ongoing "silent crises" to the ecological basis of the Carpathians.},
	language = {en},
	urldate = {2026-03-19},
	journal = {International Journal of Science and Management Studies (IJSMS)},
	author = {Ianc, Cristian Gabriel},
	month = may,
	year = {2025},
	pages = {103--110},
	file = {Volltext:C\:\\Users\\vikto\\Zotero\\storage\\TTQP8AZQ\\Ianc - 2025 - Silent Crises in the Carpathians Deforestation, Illegal Logging, and the Erosion of Ecological Resi.pdf:application/pdf},
}

@article{zhou2023,
	title = {Integration of Landsat time-series vegetation indices improves consistency of change detection},
	volume = {16},
	issn = {1753-8947},
	url = {https://doi.org/10.1080/17538947.2023.2200040},
	doi = {10.1080/17538947.2023.2200040},
	abstract = {Vegetation indices (VIs) were used to detect when and where vegetation changes occurred. However, different VIs have different or even diametrically opposite results, which obstructed the in-depth understanding of vegetation change. Therefore, this study examined the spatial and temporal consistency of five VIs (EVI; NBR; NDMI; NDVI; and NIRv) in detecting abrupt and gradual vegetation changes, and provided an ensemble algorithm which integrated the change detection results of the five indices to reduce the uncertainty of change detection using a single index. The spatial consistency of the five indices in abrupt change detection accounted for 50.6\% of the study area, but the temporal consistency was low (21.6\%). Wetness indices (NBR, NDMI) were more sensitive to negative abrupt changes, greenness indices (EVI, NDVI, NIRv) were more sensitive to positive abrupt changes; and both types of indices were similar in detecting gradual and total changes. The overall accuracy of the ensemble method was 81.60\% and higher than that of any single index in abrupt change detection. This study provides a comprehensive evaluation of the spatial and temporal inconsistencies of change detection in model-fitting errors and various types of vegetation changes. The proposed ensemble method can support robust change-detection.},
	number = {1},
	urldate = {2026-03-19},
	journal = {International Journal of Digital Earth},
	publisher = {Taylor \& Francis},
	author = {Zhou, Mingxing and Li, Dengqiu and Liao, Kuo and Lu, Dengsheng},
	month = oct,
	year = {2023},
	note = {\_eprint: https://doi.org/10.1080/17538947.2023.2200040},
	keywords = {vegetation index, Breaks for Additive Season and Trend, consistence of vegetation change, ensemble algorithm},
	pages = {1276--1299},
	file = {Full Text PDF:C\:\\Users\\vikto\\Zotero\\storage\\XPA9BJW4\\Zhou et al. - 2023 - Integration of Landsat time-series vegetation indices improves consistency of change detection.pdf:application/pdf},
}

